# Copy this file to `.env.local` and fill in your own values. `.env.local` is git-ignored.

# Anthropic API key — client-side constraint/prompt parsing (optional; a regex fallback
# runs without it). See backend/README.md.
VITE_ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------------------
# Firebase — sign-in + per-account saving of constraints & the adjacency matrix.
# OPTIONAL: leave blank to run without accounts (the login popup still shows, but only the
# "Guest" button works). To enable sign-in, do the following in the Firebase console:
#
#   1. console.firebase.google.com → create a project → Add app → Web. Copy the
#      firebaseConfig values into the variables below.
#   2. Build → Authentication → Sign-in method → enable "Email/Password".
#   3. Build → Firestore Database → Create database (Production mode). Then in the Rules tab
#      restrict each user to their own document:
#
#        rules_version = '2';
#        service cloud.firestore {
#          match /databases/{database}/documents {
#            match /users/{uid} {
#              allow read, write: if request.auth != null && request.auth.uid == uid;
#            }
#          }
#        }
#
#   4. Run `npm install firebase` (already added to package.json), then restart the dev
#      server so the new env values are picked up.
# ---------------------------------------------------------------------------------------
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
